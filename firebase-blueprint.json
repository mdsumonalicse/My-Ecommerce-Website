{
  "entities": {
    "Product": {
      "title": "Product Specs",
      "description": "Inventory product inside Amar Bazar catalogue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "banglaTitle": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "discount": { "type": "number" },
        "image": { "type": "string" },
        "images": { "type": "array" },
        "rating": { "type": "number" },
        "reviewsCount": { "type": "number" },
        "stock": { "type": "number" },
        "sold": { "type": "number" },
        "isFlashSale": { "type": "boolean" },
        "isTrending": { "type": "boolean" },
        "description": { "type": "string" },
        "banglaDescription": { "type": "string" },
        "brand": { "type": "string" }
      },
      "required": ["id", "title", "price", "stock"]
    },
    "Order": {
      "title": "Customer Order Details",
      "description": "Logged checkout order details for fulfillment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "trackingStep": { "type": "number" },
        "currentLocation": { "type": "string" },
        "currentLocationBn": { "type": "string" }
      },
      "required": ["id", "date", "items", "total", "status", "paymentMethod", "paymentStatus", "trackingStep"]
    },
    "UserAccount": {
      "title": "User Profile Settings",
      "description": "User profile meta with security roles, reward metrics, and custom permission settings",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "district": { "type": "string" },
        "avatar": { "type": "string" },
        "role": { "type": "string" },
        "permissions": { "type": "array" },
        "rewardPoints": { "type": "number" },
        "memberSince": { "type": "string" },
        "orders": { "type": "array" },
        "cartItems": { "type": "array" },
        "wishlist": { "type": "array" }
      },
      "required": ["id", "name", "email", "role", "permissions", "rewardPoints"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Public catalogue of products"
    },
    "users/{userId}": {
      "schema": "UserAccount",
      "description": "User settings and details"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Invoices and client orders"
    }
  }
}
